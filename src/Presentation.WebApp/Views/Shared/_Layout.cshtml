@{
    var pageTitle = ViewData["Title"]?.ToString();
    var title = !string.IsNullOrWhiteSpace(pageTitle) ? $"{pageTitle} | CoreFitness" : "CoreFitness | Gym & Fitness Center";

}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Presentation.WebApp</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/css/site.min.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Presentation.WebApp.styles.css" asp-append-version="true" />
</head>
<body>
    <div class="layout">
        <header>
            <partial name  ="Partials/Common/_HeaderSection.cshtml"/>
            @* @RenderSectionAsync("Hero", required:false) *@
        </header>
        <main>
            @RenderBody()
        </main>
    </div>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
