@model List<BookingViewModel>

<section class="account-bookings">

    <h2>My Bookings</h2>

    @if (!Model.Any())
    {
        <div class="booking-empty">
            <p>No upcoming bookings.</p>
        </div>
    }
    else
    {
        <div class="booking-list">

            @foreach (var booking in Model)
            {
                <article class="booking-item">

                    <div class="booking-item__content">

                        <h3>@booking.ClassName</h3>

                        <p>
                            @booking.StartTime.ToString("dddd dd MMMM yyyy")
                        </p>

                        <p>
                            @booking.StartTime.ToString("HH:mm")
                        </p>

                    </div>

                    <form asp-controller="Booking"
                          asp-action="Cancel"
                          asp-route-id="@booking.BookingId"
                          method="post">

                        <button class="booking-cancel-btn"
                                type="submit">
                            Cancel Booking
                        </button>

                    </form>

                </article>
            }

        </div>
    }

</section>