@model UserProfileViewModel

<section class="account-card" id="about-me">

    <h2>About Me</h2>


    <form class="account-form"
        asp-controller="Profile"
        asp-action="Update"
        method="post">

        @Html.AntiForgeryToken()

        <div asp-validation-summary="ModelOnly" class="text-red-500"></div>

        <div class="form-row">
            <label asp-for="FirstName">First Name</label>
            <input asp-for="FirstName" placeholder="Enter First Name" />
            <span asp-validation-for="FirstName" class="text-red-500"></span>
        </div>

        <div class="form-row">
            <label asp-for="LastName">Last Name</label>
            <input asp-for="LastName" placeholder="Enter Last Name" />
            <span asp-validation-for="LastName" class="text-red-500"></span>
        </div>

        <div class="form-row">
            <label asp-for="Email">Email Address *</label>
            <input asp-for="Email" placeholder="username@domain.com" />
            <span asp-validation-for="Email" class="text-red-500"></span>
        </div>

        <div class="form-row">
            <label asp-for="PhoneNumber">Phone Number</label>
            <input asp-for="PhoneNumber" placeholder="Enter Phone Number" />
            <span asp-validation-for="PhoneNumber" class="text-red-500"></span>
        </div>

        <div class="form-row form-row--file">
            <label>Profile Image</label>

            <div class="file-input">
                <span>Upload Profile Image</span>
                <button type="button">Browse</button>
            </div>
        </div>

        <div class="account-form__actions">
            <button class="account-save-btn" type="submit">
                Save <span>›</span>
            </button>
        </div>

    </form>

</section>