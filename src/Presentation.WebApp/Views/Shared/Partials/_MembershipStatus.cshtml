@model Presentation.WebApp.Models.MembershipViewModel

<div class="membership-status-card">

    <div class="membership-status-badge @(Model.IsActive ? "is-active" : "is-inactive")">
        @(Model.IsActive ? "Active Membership" : "Inactive Membership")
    </div>

    <h2 class="membership-title">
        @Model.MembershipType
    </h2>

    <p class="membership-subtext">
        @if (Model.IsActive)
        {
            <text>Your membership is active and giving you full access.</text>
        }
        else
        {
            <text>Your membership is not active.</text>
        }
    </p>

    <div class="membership-meta">
        <div>
            <span class="label">Start</span>
            <span class="value">@Model.StartDate.ToShortDateString()</span>
        </div>

        <div>
            <span class="label">End</span>
            <span class="value">@Model.EndDate.ToShortDateString()</span>
        </div>
    </div>

</div>