
<article class="membership-card">

    <div class="membership-card__icon">
        <i class="fa-solid fa-dumbbell"></i>
    </div>

    <h3>@Model.Name</h3>

    <div class="membership-card__divider"></div>

    <p class="membership-card__description">
        @Model.Description
    </p>

    <ul class="membership-card__features">
        @foreach (var feature in Model.Features)
        {
            <li>
                <i class="fa-solid fa-check"></i>
                <span>@feature</span>
            </li>
        }
    </ul>

    <div class="membership-card__price-box">

        <div class="membership-card__price-row">
            <div>
                <span class="membership-card__price">
                    @Model.Price.ToString("0.00")
                </span>
                <span class="membership-card__period">/monthly</span>

                <p class="membership-card__classes">
                    * Monthly 20 Classes
                </p>
            </div>

            <form asp-controller="Membership"
                  asp-action="Create"
                  method="post">

                @Html.AntiForgeryToken()

                <input type="hidden"
                       name="membershipType"
                       value="@Model.MembershipType" />

                <button type="submit" class="membership-card__button">
                    Join Now <i class="fa-solid fa-chevron-right"></i>
                </button>

            </form>
        </div>

        <div class="membership-card__price-divider"></div>

        <p class="membership-card__trial">
            Try Any Membership Free for 1 Week
        </p>

    </div>

</article>