@model Presentation.WebApp.Models.GymClassDetailsViewModel

<div class="class-details">

    <!-- HEADER -->
    <div class="class-details__header">
        <span class="class-details__category">
            @Model.Category
        </span>

        <h1 class="class-details__title">
            @Model.Name
        </h1>

        <p class="class-details__instructor">
            with @Model.Instructor
        </p>
    </div>

    <!-- BODY -->
    <div class="class-details__info">

        <div class="info-row">
            <span class="label">Time</span>
            <span class="value">
                @Model.StartTime.ToString("dddd dd MMM HH:mm")
            </span>
        </div>

        <div class="info-row">
            <span class="label">Capacity</span>
            <span class="value">
                @Model.BookedCount / @Model.Capacity
            </span>
        </div>

        <div class="info-row">
            <span class="label">Availability</span>
            <span class="value @(Model.IsFull ? "text-danger" : "text-success")">
                @(Model.IsFull ? "Full" : "Spots available")
            </span>
        </div>

    </div>

    <!-- ACTIONS -->
    <div class="class-details__actions">

        @if (Model.IsBookedByUser)
        {
            <p>DEBUG: @Model.Id</p>
            <form asp-controller="Booking"
                asp-action="Cancel"
                asp-route-id="@Model.Id"
                method="post">
                <button class="btn class-btn--danger">
                    Cancel Booking
                </button>
            </form>
        }
        else if (Model.IsFull)
        {
            <button class="btn class-btn--secondary" disabled>
                Class Full
            </button>
        }
        else
        {
            <form asp-controller="Booking"
                asp-action="Create"
                asp-route-id="@Model.Id"
                method="post">
                <button class="btn class-btn--primary">
                    Book Class
                </button>
            </form>
        }

        <a asp-action="Index" class="btn class-btn--secondary">
            Back
        </a>

    </div>

</div>