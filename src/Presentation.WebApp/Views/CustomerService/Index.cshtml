@{
    ViewData["Title"] = "Customer Service";
}

<section class="customer-service-page">

    <h1 class="customer-service-title">Customer Service</h1>

    <section class="contact-section">

        <div class="contact-image-card">
            <img src="~/images/contact-us-image.png" alt="Customer service" />

            <div class="contact-info-card">
                <div>
                    <strong>Phone Number</strong>
                    <span>+(46) 8 410 521 00</span>
                </div>

                <div>
                    <strong>Email Address</strong>
                    <span>info@corefitness.se</span>
                </div>
            </div>
        </div>

        <div class="contact-form-card">

            <h2>Contact Us Today</h2>

            <p>
                Ready to begin your fitness journey? Contact CoreFitness today and let our expert trainers guide you with the right program and support.
            </p>

            <form class="contact-form">

                <div class="contact-grid">
                    <div>
                        <label>First Name *</label>
                        <input type="text" placeholder="Enter First Name" />
                    </div>

                    <div>
                        <label>Last Name *</label>
                        <input type="text" placeholder="Enter Last Name" />
                    </div>

                    <div>
                        <label>Email Address *</label>
                        <input type="email" placeholder="Enter Email Address" />
                    </div>

                    <div>
                        <label>Phone Number</label>
                        <input type="tel" placeholder="Enter Phone Number" />
                    </div>
                </div>

                <div>
                    <label>Message *</label>
                    <textarea placeholder="Message..."></textarea>
                </div>

                <button type="submit" class="contact-submit-btn">
                    Submit Message <span>›</span>
                </button>

            </form>

        </div>

    </section>

    <section class="customer-faq-section">

        <div class="customer-faq-image">
            <img src="~/images/faq-image.png" alt="Gym training" />
        </div>

        <div class="customer-faq-content">

            <span class="section-pill">Frequently Asked Questions</span>

            <h2>Common questions about gym and training</h2>

            <div class="faq-list">

                <details open>
                    <summary>Q1. Do I need prior gym experience to Join CoreFitness?</summary>
                    <p>
                        No, CoreFitness is designed for all fitness levels. Our trainers guide beginners with proper techniques and structured workout plans.
                    </p>
                    <ul>
                        <li>Every new member receives a personalized introduction to equipments</li>
                        <li>Workouts are designed to grow with you, ensuring beginners can start safely.</li>
                    </ul>
                </details>

                <details>
                    <summary>Q2. What facilities are included with the membership?</summary>
                    <p>Members get access to gym facilities, lockers and selected training areas depending on membership type.</p>
                </details>

                <details>
                    <summary>Q3. Can I try the gym before taking a membership?</summary>
                    <p>Yes, you can try a membership free for one week.</p>
                </details>

                <details>
                    <summary>Q4. Are there group workout programs available?</summary>
                    <p>Yes, we offer several group workout classes.</p>
                </details>

                <details>
                    <summary>Q5. Is nutrition guidance included in the plans?</summary>
                    <p>Nutrition guidance may be included depending on your membership plan.</p>
                </details>

            </div>

        </div>

    </section>

</section>
<partial name="~/Views/Shared/Partials/Common/_Footer.cshtml" />